# Copy to .env and fill in values (never commit .env)

# PayPal (server: secret + mode; client uses PUBLIC_ below)
PAYPAL_CLIENT_ID=example
PAYPAL_CLIENT_SECRET=example
PAYPAL_MODE=sandbox

# PayPal — exposed to the browser for the JS SDK (must match PAYPAL_CLIENT_ID)
PUBLIC_PAYPAL_CLIENT_ID=example

# Zoom (Server-to-Server OAuth app)
ZOOM_ACCOUNT_ID=example
ZOOM_CLIENT_ID=example
ZOOM_CLIENT_SECRET=example
# IANA timezone used to treat "Monday" vs "Tuesday" for class nights (default America/Los_Angeles)
# ZOOM_CLASS_TIMEZONE=America/Los_Angeles
# Host whose scheduled meetings appear in the booking widget (email or user id).
# If unset, requests use /users/me/meetings (may not work for all S2S setups).
# ZOOM_HOST_EMAIL=you@yourdomain.com
# ZOOM_HOST_USER_ID=
# Comma-separated Zoom meeting IDs to always fetch (if list API returns nothing)
# ZOOM_BOOKABLE_MEETING_IDS=88312217147

# Email (Resend)
RESEND_API_KEY=example
ADMIN_EMAIL=example
FROM_EMAIL=example
