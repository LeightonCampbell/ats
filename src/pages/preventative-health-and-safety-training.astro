---
import BaseLayout from "../layouts/BaseLayout.astro";
import BookingWidget from "../components/BookingWidget.tsx";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const paypalClientId = import.meta.env.PUBLIC_PAYPAL_CLIENT_ID ?? "";
---

<BaseLayout title="Enroll | Alert Training Services">
  <SiteHeader />
  <main
    style="min-height:100vh; background:#f5f5f7; padding: 80px 24px; font-family:Poppins,-apple-system,BlinkMacSystemFont,sans-serif;"
  >
      <div style="max-width:560px; margin:0 auto;">
        <div style="text-align:center; margin-bottom:40px;">
          <div
            style="font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#E02B2B;margin-bottom:10px;"
          >
            Enroll Now
          </div>
          <h1
            style="font-size:2.2rem;font-weight:700;color:#1B3A5C;letter-spacing:-0.03em;margin-bottom:12px;font-family:Poppins,-apple-system,BlinkMacSystemFont,sans-serif;"
          >
            Choose Upcoming Class
          </h1>
          <p style="color:#515154;font-size:1rem;line-height:1.65;font-weight:300;">
            <strong>Please Note:</strong> Classes are held on Mondays &amp; Tuesdays from 6 PM
            to 10 PM. Select your Monday start date below — the matching
            Tuesday session is included for the same week. Fill in your details
            and pay; your Zoom link will be emailed to you
            instantly.
          </p>
        </div>

        <div
          style="background:white;border-radius:16px;border:1px solid rgba(0,0,0,0.08);padding:40px;"
        >
          <BookingWidget client:load paypalClientId={paypalClientId} />
        </div>

        <p style="text-align:center;margin-top:20px;font-size:13px;color:#86868b;font-weight:300;">
          🔒 Payments secured by PayPal · Questions? Call <a
            href="tel:3239216244"
            style="color:#1B3A5C;">323-921-6244</a>
        </p>
      </div>
  </main>
  <SiteFooter />
</BaseLayout>
