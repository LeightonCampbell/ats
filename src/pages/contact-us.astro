---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Contact Us | Alert Training Services"
  description="Contact Alert Training Services in Los Angeles for EMSA-approved health and safety training questions."
  canonical="https://www.alerttrainingservices.com/contact-us"
>
  <SiteHeader />
  <style>
    .contact-shell section {
      padding: 0;
    }
  </style>
  <main class="contact-shell" style="background:#f5f5f7; padding: 50px 24px;">
    <section style="max-width:1080px; margin:0 auto;">
      <div style="text-align:center; margin-bottom:34px;">
        <div
          style="font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#E02B2B;margin-bottom:10px;"
        >
          Contact Us
        </div>
        <h1 style="font-size:2.35rem;font-weight:700;color:#1B3A5C;letter-spacing:-0.03em;margin-bottom:12px;">
          We are here to help
        </h1>
        <p style="max-width:760px;margin:0 auto;color:#515154;font-size:1rem;line-height:1.7;">
          Have a question about class schedules, enrollment, or certificate
          delivery? Reach out and our team will get back to you.
        </p>
      </div>

      <div
        style="display:grid;grid-template-columns:1fr 1.2fr;gap:24px;align-items:start;"
      >
        <aside style="display:grid;gap:14px;">
          <article style="background:white;border:1px solid rgba(0,0,0,0.08);border-radius:16px;padding:22px;">
            <h2 style="font-size:1.1rem;color:#1B3A5C;margin-bottom:10px;">Get in touch</h2>
            <p style="color:#515154;line-height:1.7;margin-bottom:10px;">
              We answer calls and messages during business hours.
            </p>
            <p style="margin:0 0 6px;">
              <a href="tel:3239216244" style="color:#1B3A5C;font-weight:600;text-decoration:none;">
                323-921-6244
              </a>
            </p>
            <p style="margin:0;">
              <a href="mailto:info@alerttrainingservices.com" style="color:#1B3A5C;font-weight:600;text-decoration:none;">
                info@alerttrainingservices.com
              </a>
            </p>
          </article>

          <article style="background:white;border:1px solid rgba(0,0,0,0.08);border-radius:16px;padding:22px;">
            <h2 style="font-size:1.1rem;color:#1B3A5C;margin-bottom:10px;">Work hours</h2>
            <p style="color:#515154;line-height:1.9;margin:0;">
              <strong>Mon - Sat:</strong> 9:00 AM - 5:00 PM<br />
              <strong>Sunday:</strong> Closed
            </p>
          </article>

          <article style="background:#1B3A5C;border-radius:16px;padding:22px;">
            <h2 style="font-size:1.1rem;color:white;margin-bottom:10px;">Need to enroll now?</h2>
            <p style="color:rgba(255,255,255,0.82);line-height:1.7;margin-bottom:14px;">
              Reserve your spot in our next class and complete registration in
              minutes.
            </p>
            <a
              href="/preventative-health-and-safety-training"
              style="display:inline-block;background:#E02B2B;color:white;text-decoration:none;padding:10px 20px;border-radius:999px;font-weight:700;"
            >
              Enroll Now
            </a>
          </article>
        </aside>

        <article style="background:white;border:1px solid rgba(0,0,0,0.08);border-radius:16px;padding:28px;">
          <h2 style="font-size:1.3rem;color:#1B3A5C;margin-bottom:8px;">Send us a message</h2>
          <p style="color:#515154;line-height:1.7;margin-bottom:18px;">
            Complete the form and we will reply as soon as possible.
          </p>

          <form onsubmit="handleSubmit(event)">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div>
                <label for="fullName" style="display:block;font-size:0.72rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:#86868B;margin-bottom:6px;">Full Name</label>
                <input
                  id="fullName"
                  type="text"
                  required
                  placeholder="Your full name"
                  style="width:100%;background:#f5f5f7;border:1px solid rgba(0,0,0,0.08);border-radius:10px;padding:12px 14px;font-family:Poppins,sans-serif;font-size:0.92rem;"
                />
              </div>
              <div>
                <label for="phone" style="display:block;font-size:0.72rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:#86868B;margin-bottom:6px;">Phone Number</label>
                <input
                  id="phone"
                  type="tel"
                  required
                  placeholder="(323) 555-1234"
                  style="width:100%;background:#f5f5f7;border:1px solid rgba(0,0,0,0.08);border-radius:10px;padding:12px 14px;font-family:Poppins,sans-serif;font-size:0.92rem;"
                />
              </div>
            </div>

            <div style="margin-top:12px;">
              <label for="email" style="display:block;font-size:0.72rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:#86868B;margin-bottom:6px;">Email</label>
              <input
                id="email"
                type="email"
                required
                placeholder="you@example.com"
                style="width:100%;background:#f5f5f7;border:1px solid rgba(0,0,0,0.08);border-radius:10px;padding:12px 14px;font-family:Poppins,sans-serif;font-size:0.92rem;"
              />
            </div>

            <div style="margin-top:12px;">
              <label for="message" style="display:block;font-size:0.72rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:#86868B;margin-bottom:6px;">What can we help with?</label>
              <textarea
                id="message"
                required
                placeholder="Ask a question about class schedules, attendance rules, or registration."
                style="width:100%;height:120px;background:#f5f5f7;border:1px solid rgba(0,0,0,0.08);border-radius:10px;padding:12px 14px;font-family:Poppins,sans-serif;font-size:0.92rem;resize:vertical;"
              ></textarea>
            </div>

            <button
              id="submitBtn"
              type="submit"
              style="width:100%;margin-top:14px;background:#1B3A5C;color:white;border:none;padding:14px;border-radius:999px;font-family:Poppins,sans-serif;font-size:0.95rem;font-weight:700;cursor:pointer;"
            >
              Send Message
            </button>
          </form>
        </article>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
