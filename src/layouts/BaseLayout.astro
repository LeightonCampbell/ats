---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Alert Training Services | Safety Training | Los Angeles, CA",
  description = "EMSA-approved safety training in Los Angeles. Get certified for $80. Evening classes for daycares, schools, and businesses.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --navy: #1b3a5c;
        --navy-deep: #122844;
        --navy-pale: #eef2f7;
        --navy-mid: #c8d8e8;
        --red: #e02b2b;
        --red-pale: #fdeaea;
        --white: #ffffff;
        --bg: #f5f5f7;
        --text: #1d1d1f;
        --text2: #515154;
        --text3: #86868b;
        --border: rgba(0, 0, 0, 0.08);
        --radius: 16px;
        --radius-sm: 10px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
        color: var(--text);
        background: var(--white);
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
        line-height: 1.5;
      }

      nav {
        position: sticky;
        top: 0;
        z-index: 200;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: saturate(180%) blur(20px);
        -webkit-backdrop-filter: saturate(180%) blur(20px);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 max(24px, 5vw);
        height: 64px;
      }

      .nav-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
      }
      .nav-brand svg {
        width: 44px;
        height: 44px;
        flex-shrink: 0;
      }
      .nav-brand img {
        height: 44px;
        width: auto;
        flex-shrink: 0;
        object-fit: contain;
      }
      .nav-name {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--navy);
        letter-spacing: -0.01em;
        line-height: 1.2;
      }
      .nav-name span {
        display: block;
        font-weight: 400;
        font-size: 0.7rem;
        color: var(--text3);
        letter-spacing: 0.02em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 28px;
        list-style: none;
      }
      .nav-links a {
        font-size: 0.84rem;
        font-weight: 500;
        color: var(--text2);
        text-decoration: none;
        transition: color 0.15s;
      }
      .nav-links a:hover {
        color: var(--navy);
      }

      .nav-btn {
        background: var(--navy);
        color: var(--white) !important;
        padding: 7px 18px;
        border-radius: 980px;
        font-size: 0.82rem !important;
        font-weight: 600 !important;
        transition: background 0.15s !important;
      }
      .nav-btn:hover {
        background: var(--navy-deep) !important;
      }

      .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 6px;
      }
      .hamburger span {
        display: block;
        width: 22px;
        height: 1.5px;
        background: var(--navy);
        border-radius: 2px;
        transition: all 0.25s;
      }

      .mobile-menu {
        display: none;
        flex-direction: column;
        position: fixed;
        top: 64px;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.97);
        backdrop-filter: blur(20px);
        padding: 32px 28px;
        z-index: 199;
        overflow-y: auto;
      }
      .mobile-menu.open {
        display: flex;
      }
      .mobile-menu a {
        color: var(--text);
        font-size: 1.1rem;
        font-weight: 500;
        text-decoration: none;
        padding: 16px 0;
        border-bottom: 1px solid var(--border);
      }
      .mob-enroll {
        margin-top: 24px;
        background: var(--navy);
        color: var(--white) !important;
        text-align: center;
        padding: 16px !important;
        border-radius: 14px;
        font-weight: 700 !important;
        border: none !important;
      }
      .mob-phone {
        color: var(--red) !important;
        border-bottom: none !important;
      }

      .hero {
        min-height: 92svh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 80px 24px 64px;
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(
            180deg,
            rgba(27, 58, 92, 0.92) 0%,
            rgba(27, 58, 92, 0.84) 45%,
            rgba(27, 58, 92, 0.88) 100%
          ),
          url("/images/cna-training-alert-training-services.jpg") center / cover no-repeat
          var(--navy);
      }

      .hero h1 {
        color: var(--white);
      }

      .hero .hero-sub {
        color: rgba(255, 255, 255, 0.9);
      }

      .hero .eyebrow-pill {
        background: rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.95);
        border-color: rgba(255, 255, 255, 0.22);
      }

      .hero .hero-proof {
        border-top-color: rgba(255, 255, 255, 0.22);
      }

      .hero .proof-num {
        color: var(--white);
      }

      .hero .proof-label {
        color: rgba(255, 255, 255, 0.62);
      }

      .hero .btn-ghost {
        border-color: rgba(255, 255, 255, 0.45);
        color: var(--white);
      }

      .hero .btn-ghost:hover {
        border-color: rgba(255, 255, 255, 0.85);
        color: var(--white);
      }

      .eyebrow-pill {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--navy-pale);
        color: var(--navy);
        border: 1px solid var(--navy-mid);
        padding: 5px 14px;
        border-radius: 980px;
        font-size: 0.74rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        margin-bottom: 28px;
        animation: fadeUp 0.5s ease both;
      }
      .eyebrow-pill .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--red);
        flex-shrink: 0;
      }

      h1 {
        font-size: clamp(2.8rem, 7.5vw, 5.6rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.03;
        color: var(--navy);
        animation: fadeUp 0.5s 0.08s ease both;
      }
      h1 em {
        font-style: normal;
        color: var(--red);
      }

      .hero-sub {
        margin-top: 20px;
        font-size: clamp(1rem, 2vw, 1.18rem);
        color: var(--text2);
        font-weight: 400;
        line-height: 1.6;
        max-width: 500px;
        animation: fadeUp 0.5s 0.16s ease both;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
        margin-top: 36px;
        animation: fadeUp 0.5s 0.24s ease both;
      }

      .btn-primary {
        background: var(--navy);
        color: var(--white);
        padding: 15px 32px;
        border-radius: 980px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        letter-spacing: -0.01em;
        transition: background 0.15s, transform 0.15s;
        display: inline-block;
      }
      .btn-primary:hover {
        background: var(--navy-deep);
        transform: scale(1.02);
      }

      .btn-ghost {
        background: transparent;
        color: var(--navy);
        border: 1.5px solid var(--navy-mid);
        padding: 13px 32px;
        border-radius: 980px;
        font-size: 1rem;
        font-weight: 500;
        text-decoration: none;
        letter-spacing: -0.01em;
        transition: border-color 0.15s, transform 0.15s;
        display: inline-block;
      }
      .btn-ghost:hover {
        border-color: var(--navy);
        transform: scale(1.02);
      }

      .hero-proof {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 40px;
        margin-top: 60px;
        padding-top: 40px;
        border-top: 1px solid var(--border);
        animation: fadeUp 0.5s 0.32s ease both;
      }
      .proof-item {
        text-align: center;
      }
      .proof-num {
        font-size: 2.2rem;
        font-weight: 700;
        letter-spacing: -0.04em;
        color: var(--navy);
        line-height: 1;
      }
      .proof-num sup {
        font-size: 1rem;
        vertical-align: super;
      }
      .proof-label {
        font-size: 0.71rem;
        font-weight: 600;
        color: var(--text3);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-top: 5px;
      }

      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(18px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      section {
        padding: 96px max(24px, 5vw);
      }
      .container {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--red);
        margin-bottom: 10px;
      }

      h2 {
        font-size: clamp(2rem, 4.5vw, 3.1rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.07;
        color: var(--navy);
      }

      .section-lead {
        color: var(--text2);
        font-size: 1.05rem;
        line-height: 1.65;
        max-width: 480px;
        margin-top: 14px;
      }

      .benefits {
        background: var(--bg);
      }

      .benefit-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2px;
        margin-top: 48px;
        border-radius: var(--radius);
        overflow: hidden;
        border: 1px solid var(--border);
      }

      .benefit-card {
        background: var(--white);
        padding: 40px 32px;
        transition: background 0.2s;
      }
      .benefit-card:hover {
        background: var(--navy-pale);
      }

      .benefit-icon {
        width: 46px;
        height: 46px;
        border-radius: 11px;
        background: var(--navy-pale);
        border: 1px solid var(--navy-mid);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
      }
      .benefit-icon svg {
        width: 20px;
        height: 20px;
        stroke: var(--navy);
        fill: none;
        stroke-width: 1.8;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .benefit-card h3 {
        font-size: 1rem;
        font-weight: 700;
        color: var(--navy);
        letter-spacing: -0.02em;
        margin-bottom: 8px;
      }
      .benefit-card p {
        font-size: 0.9rem;
        color: var(--text2);
        line-height: 1.65;
      }

      .course-card {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        border-radius: var(--radius);
        overflow: hidden;
        border: 1px solid var(--border);
        margin-top: 48px;
      }

      .course-visual {
        background: var(--navy);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 56px 40px;
        gap: 22px;
        min-height: 340px;
        position: relative;
        overflow: hidden;
      }
      .course-visual::before,
      .course-visual::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        border: 1px solid rgba(255, 255, 255, 0.06);
      }
      .course-visual::before {
        width: 280px;
        height: 280px;
        top: -70px;
        right: -70px;
      }
      .course-visual::after {
        width: 180px;
        height: 180px;
        bottom: -50px;
        left: -50px;
      }

      .course-visual svg.shield {
        width: 80px;
        height: 80px;
        position: relative;
        z-index: 1;
      }

      .emsa-pill {
        background: rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 6px 18px;
        border-radius: 980px;
        font-size: 0.73rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        position: relative;
        z-index: 1;
      }

      .stars-visual {
        color: #f5a623;
        font-size: 0.92rem;
        letter-spacing: 1.5px;
        position: relative;
        z-index: 1;
      }
      .stars-visual span {
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.76rem;
        letter-spacing: 0;
        margin-left: 4px;
      }

      .course-info {
        padding: 44px;
        background: var(--white);
      }
      .course-info h3 {
        font-size: 1.45rem;
        font-weight: 700;
        color: var(--navy);
        letter-spacing: -0.025em;
        margin-bottom: 8px;
      }
      .course-desc {
        font-size: 0.93rem;
        color: var(--text2);
        line-height: 1.65;
        margin-bottom: 32px;
      }

      .meta-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 32px;
      }
      .meta-pill {
        background: var(--bg);
        border-radius: var(--radius-sm);
        padding: 13px 16px;
        border: 1px solid var(--border);
      }
      .meta-pill .ml {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--text3);
        margin-bottom: 3px;
      }
      .meta-pill .mv {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--navy);
      }

      .price-row {
        display: flex;
        align-items: flex-end;
        gap: 12px;
        margin-bottom: 28px;
      }
      .price {
        font-size: 3rem;
        font-weight: 700;
        letter-spacing: -0.04em;
        color: var(--navy);
        line-height: 1;
      }
      .price-note {
        font-size: 0.83rem;
        color: var(--text3);
        line-height: 1.5;
        padding-bottom: 5px;
      }

      .audience {
        background: var(--navy);
      }
      .audience h2 {
        color: var(--white);
      }
      .audience .eyebrow {
        color: #e87070;
      }
      .audience .section-lead {
        color: rgba(255, 255, 255, 0.5);
      }

      .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 11px;
        margin-top: 48px;
      }
      .chip {
        display: flex;
        align-items: center;
        gap: 9px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 980px;
        padding: 11px 20px;
        font-size: 0.92rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.8);
        transition: all 0.2s;
        cursor: default;
      }
      .chip:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.25);
        color: var(--white);
      }
      .chip-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--red);
        flex-shrink: 0;
      }

      .why {
        background: var(--bg);
      }
      .why-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
        margin-top: 56px;
      }

      .why-item {
        display: flex;
        gap: 18px;
        padding: 24px 0;
        border-bottom: 1px solid var(--border);
      }
      .why-item:last-child {
        border-bottom: none;
      }
      .why-num {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--text3);
        letter-spacing: 0.04em;
        min-width: 26px;
        padding-top: 3px;
      }
      .why-text h4 {
        font-size: 0.98rem;
        font-weight: 700;
        color: var(--navy);
        letter-spacing: -0.015em;
        margin-bottom: 6px;
      }
      .why-text p {
        font-size: 0.88rem;
        color: var(--text2);
        line-height: 1.65;
      }

      .instructor-card {
        background: var(--white);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 40px;
        text-align: center;
        position: sticky;
        top: 70px;
      }
      .i-avatar {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        background: var(--navy);
        margin: 0 auto 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 3px solid var(--navy-mid);
      }
      .i-avatar svg {
        width: 42px;
        height: 42px;
      }
      .i-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--navy);
        letter-spacing: -0.02em;
      }
      .i-title {
        font-size: 0.8rem;
        color: var(--text3);
        margin-top: 3px;
      }
      .i-stars {
        color: #f5a623;
        font-size: 1rem;
        letter-spacing: 2px;
        margin: 14px 0 4px;
      }
      .i-quote {
        font-size: 0.86rem;
        color: var(--text2);
        line-height: 1.65;
        font-style: italic;
      }
      .i-source {
        font-size: 0.74rem;
        color: var(--text3);
        margin-top: 6px;
      }
      .i-badge {
        display: inline-block;
        margin-top: 20px;
        background: var(--navy-pale);
        color: var(--navy);
        border: 1px solid var(--navy-mid);
        padding: 5px 13px;
        border-radius: 980px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .t-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-top: 48px;
      }

      .t-card {
        background: var(--bg);
        border-radius: var(--radius);
        padding: 36px;
        border: 1px solid var(--border);
        transition: border-color 0.2s;
      }
      .t-card:hover {
        border-color: var(--navy-mid);
      }
      .t-stars {
        color: #f5a623;
        font-size: 0.83rem;
        letter-spacing: 2px;
        margin-bottom: 16px;
      }
      .t-body {
        font-size: 0.93rem;
        color: var(--text);
        line-height: 1.72;
      }
      .t-author {
        display: flex;
        align-items: center;
        gap: 11px;
        margin-top: 22px;
      }
      .t-av {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: var(--navy);
        color: var(--white);
        font-size: 0.76rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .t-name {
        font-size: 0.86rem;
        font-weight: 700;
        color: var(--navy);
      }

      .cta-strip {
        background: var(--navy);
        padding: 96px max(24px, 5vw);
        text-align: center;
      }
      .cta-strip h2 {
        color: var(--white);
      }
      .cta-strip p {
        color: rgba(255, 255, 255, 0.5);
        font-size: 1.05rem;
        max-width: 440px;
        margin: 14px auto 36px;
        line-height: 1.65;
      }

      .btn-light {
        background: var(--white);
        color: var(--navy);
        padding: 15px 36px;
        border-radius: 980px;
        font-size: 1rem;
        font-weight: 700;
        text-decoration: none;
        letter-spacing: -0.01em;
        display: inline-block;
        transition: transform 0.15s;
      }
      .btn-light:hover {
        transform: scale(1.02);
      }

      .contact {
        background: var(--bg);
      }
      .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1.1fr;
        gap: 60px;
        margin-top: 52px;
      }

      .info-stack {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .info-row {
        display: flex;
        align-items: center;
        gap: 14px;
        background: var(--white);
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        padding: 15px 18px;
      }
      .info-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: var(--navy-pale);
        border: 1px solid var(--navy-mid);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .info-icon svg {
        width: 15px;
        height: 15px;
        stroke: var(--navy);
        fill: none;
        stroke-width: 1.8;
        stroke-linecap: round;
        stroke-linejoin: round;
      }
      .info-label {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--text3);
        margin-bottom: 2px;
      }
      .info-val {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
      }
      .info-val:hover {
        color: var(--red);
      }

      .hours-card {
        background: var(--white);
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        overflow: hidden;
        margin-top: 10px;
      }
      .hours-head {
        background: var(--navy);
        color: var(--white);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 9px 18px;
      }
      .hours-row {
        display: flex;
